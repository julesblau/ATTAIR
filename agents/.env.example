# ATTAIRE Discord Bot — Environment Variables
# Copy to .env and fill in values

# ─── Required ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHAT_CHANNEL_ID=your_chat_channel_id
ANTHROPIC_API_KEY=your_anthropic_api_key

# ─── Optional ─────────────────────────────────────────────────────────────────
DISCORD_LOGS_CHANNEL_ID=your_logs_channel_id
GH_TOKEN=your_github_token
GH_REPO=username/ATTAIR

# ─── Hosting ──────────────────────────────────────────────────────────────────
# These are auto-set by Railway/Render/Fly. Only set manually for VPS.
# HOSTED=true
# HEALTH_PORT=8081
# PORT=8081
# REPO_ROOT=/app

# ─── Supabase (for db-query.js agent tool) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key
