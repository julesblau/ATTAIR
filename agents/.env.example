# ATTAIRE Discord Bot — Environment Variables
# Copy to .env and fill in values

# ─── Required ─────────────────────────────────────────────────────────────────
DISCORD_TOKEN=your_discord_bot_token
DISCORD_CHAT_CHANNEL_ID=your_chat_channel_id
# Note: No ANTHROPIC_API_KEY needed — bot uses Claude CLI (covered by subscription)

# ─── Optional (but required for Railway hosted deployment) ───────────────────
DISCORD_LOGS_CHANNEL_ID=your_logs_channel_id
GH_TOKEN=your_github_token              # GitHub PAT — needed for git push/pull inside Docker
GH_REPO=username/ATTAIR                 # GitHub repo — e.g. jubla/ATTAIR

# ─── Hosting ──────────────────────────────────────────────────────────────────
# These are auto-set by Railway/Render/Fly. Only set manually for VPS.
# HOSTED=true
# HEALTH_PORT=8081
# PORT=8081
# REPO_ROOT=/app

# ─── Supabase (for db-query.js agent tool) ───────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key

# ─── Beli Reservation Monitor (beli-monitor.js) ───────────────────────────────
BELI_EMAIL=your_beli_email@example.com
BELI_PASSWORD=your_beli_password
NTFY_TOPIC=your-ntfy-topic-name        # e.g. jules-beli-reservations
NTFY_URL=https://ntfy.sh               # or your self-hosted ntfy server
POLL_INTERVAL_MS=60000                 # 60s default; set lower for faster alerts
