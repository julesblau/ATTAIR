# ──────────────────────────────────────────────────────────
# ATTAIR Frontend — Environment Variables
# Copy to .env.local and fill in your values.
# Set these in Vercel project settings for production.
# ──────────────────────────────────────────────────────────

# Backend API URL (Railway for production, localhost for dev)
VITE_API_BASE=http://localhost:3000

# Supabase public config (anon key is safe to expose — protected by RLS)
# Find these at: Supabase dashboard → Project Settings → API
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbG...your-anon-key

# Optional: Enable Apple OAuth (requires Apple Developer account setup)
VITE_APPLE_AUTH_ENABLED=false
